# Aegis402 — Environment Variables Reference
# Copy this file to .env and fill in your values before running.
# NEVER commit your real .env file to version control.
# O .gitignore já ignora todos os .env (exceto este exemplo).

# ══════════════════════════════════════════════════════════════
# VERCEL DEPLOYMENT — Configurar no Dashboard
# Go to: vercel.com → Your Project → Settings → Environment Variables
# ══════════════════════════════════════════════════════════════
#
# These are SERVER-SIDE variables (not exposed to the browser bundle).
# Configure them in the Vercel Dashboard, NOT in this file for production.
#
# ┌─────────────────────────────────────────────────────────┐
# │  VERCEL DASHBOARD → Settings → Environment Variables    │
# │                                                         │
# │  PROVIDER_PUBLIC_KEY   = G... (receives XLM payments)  │
# │  STELLAR_SECRET_KEY    = S... (server-side signing)     │
# └─────────────────────────────────────────────────────────┘

# Stellar public key of the API Data Provider (receives XLM payments from agents)
# Used in api/data.js serverless function — server-side only, never in browser bundle
PROVIDER_PUBLIC_KEY=""

# Stellar secret key for server-side signing operations
# Reserved for future on-chain payment verification in api/data.js
# NEVER prefix with VITE_ — would expose it to the browser bundle
STELLAR_SECRET_KEY=""

# ══════════════════════════════════════════════════════════════
# LOCAL DEV — api_provider/server.js (node server.js)
# ══════════════════════════════════════════════════════════════

# TCP port the legacy Express L402 server listens on (local dev only)
PORT=3001

# ══════════════════════════════════════════════════════════════
# FRONTEND (React + Vite) — VITE_ prefix = exposed to browser
# Configure in .env locally, or in Vercel Dashboard for production
# ══════════════════════════════════════════════════════════════
#
# ⚠️  WARNING: All VITE_ variables end up in the JS bundle.
#     Only use testnet keys here. Never use mainnet keys in client-side code.

# Stellar public key of the corporate treasury account (read-only display in UI)
VITE_TREASURY_PUBLIC_KEY=""

# Stellar secret key of the corporate treasury (signs Replenish Pool transactions)
# WARNING: Testnet ONLY — this key lives in the browser bundle
VITE_TREASURY_SECRET_KEY=""

# Stellar public key of the autonomous agent wallet
VITE_AGENT_PUBLIC_KEY=""

# Stellar secret key of the agent that the frontend orchestrates on behalf of
# WARNING: Testnet ONLY — this key lives in the browser bundle
VITE_AGENT_SECRET_KEY=""

# Deployed Soroban contract ID of the Aegis Shielded Pool (Testnet)
VITE_CONTRACT_ID=""

# Google Gemini API key for the Aegis AI Auditor panel
# Get yours at: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=""
