# Aegis402 — Environment Variables Reference
# Copy this file to .env and fill in your values before running.
# NEVER commit your real .env file to version control.

# ==========================================
# 1. API Provider (Node.js / Express — cd api_provider)
# ==========================================

# TCP port the L402 middleware server listens on
PORT=3001

# Stellar public key of the API Data Provider (receives XLM payments)
PROVIDER_PUBLIC_KEY=""

# Stellar secret key of the API Data Provider (used for validation only — keep private)
PROVIDER_SECRET_KEY=""

# ==========================================
# 2. Agent Client (Autonomous AI Consumer — cd agent_client)
# ==========================================

# Full URL of the protected API endpoint
PROVIDER_URL="http://localhost:3001/api/data"

# Stellar public key of the autonomous agent wallet
AGENT_PUBLIC_KEY=""

# Stellar secret key of the autonomous agent wallet (signs Soroban transactions)
AGENT_SECRET_KEY=""

# Deployed Soroban contract ID of the Aegis Shielded Pool (Testnet)
CONTRACT_ID=""

# ==========================================
# 3. Frontend Dashboard (React + Vite — npm run dev)
# All VITE_ variables are safe to expose to the browser bundle.
# ==========================================

# Stellar public key of the corporate treasury account (read-only display)
VITE_TREASURY_PUBLIC_KEY=""

# Stellar secret key of the corporate treasury (signs Replenish Pool transactions)
# WARNING: Only use a testnet key here — never a mainnet key in client-side code.
VITE_TREASURY_SECRET_KEY=""

# Stellar secret key of the agent that the frontend orchestrates on behalf of
VITE_AGENT_SECRET_KEY=""

# Deployed Soroban contract ID (same as CONTRACT_ID above, prefixed for Vite)
VITE_CONTRACT_ID=""

# Google Gemini API key for the Aegis AI Auditor
# Get yours at: https://makersuite.google.com/app/apikey
VITE_GEMINI_API_KEY=""
